<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_ai_suggestion_form" model="ir.ui.view">
        <field name="name">medical.ai.suggestion.form</field>
        <field name="model">medical.ai.suggestion</field>
        <field name="arch" type="xml">
            <form>
                <field name="mode" invisible="1"/>
                <field name="encounter_id" invisible="1"/>
                <field name="log_id" invisible="1"/>

                <div class="alert alert-info" role="alert">
                    <strong>AI-generated draft.</strong>
                    Review and edit it before applying — you remain
                    responsible for the clinical record.
                </div>

                <!-- Report draft: the six free-text sections that go on
                     the printed medical report. Rendered in the same order
                     and with the same headings as the PDF, so the doctor
                     sees what each section will look like before applying. -->
                <div invisible="mode != 'report'">
                    <separator string="Clinical Summary"/>
                    <field name="report_history_present_illness"
                           nolabel="1"/>

                    <separator string="Therapies Administered"/>
                    <field name="report_therapies_administered"
                           nolabel="1"/>

                    <separator string="Medications Prescribed upon Discharge"/>
                    <field name="report_discharge_medication_notes"
                           nolabel="1"/>

                    <separator string="Medical Recommendation"/>
                    <field name="report_plan"
                           nolabel="1"/>

                    <separator string="Condition at Discharge"/>
                    <field name="report_discharge_condition"
                           nolabel="1"/>

                    <separator string="Conclusion"/>
                    <field name="report_discharge_conclusion"
                           nolabel="1"/>
                </div>

                <!-- Diagnosis suggestions -->
                <group invisible="mode != 'diagnosis'">
                    <field name="suggested_diagnosis_ids"
                           widget="many2many_tags" nolabel="1"/>
                </group>

                <!-- Free-text output: rationale / summary / safety findings -->
                <group invisible="mode == 'report'">
                    <field name="result_text" nolabel="1" readonly="1"/>
                </group>

                <footer>
                    <button name="action_apply_report" type="object"
                            string="Apply to Encounter" class="btn-primary"
                            invisible="mode != 'report'"/>
                    <button name="action_apply_diagnoses" type="object"
                            string="Add Diagnoses to Encounter"
                            class="btn-primary"
                            invisible="mode != 'diagnosis'"/>
                    <button string="Close" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
