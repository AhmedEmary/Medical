<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_ai_suggestion_form" model="ir.ui.view">
        <field name="name">medical.ai.suggestion.form</field>
        <field name="model">medical.ai.suggestion</field>
        <field name="arch" type="xml">
            <form>
                <field name="mode" invisible="1"/>
                <field name="encounter_id" invisible="1"/>
                <field name="case_id" invisible="1"/>
                <field name="log_id" invisible="1"/>

                <div class="alert alert-info" role="alert">
                    <strong>AI-generated draft.</strong>
                    Review and edit it before applying — you remain
                    responsible for the clinical record.
                </div>

                <!-- Report draft: the nine free-text sections that go on
                     the printed medical report. Rendered in the same order
                     and with the same headings as the PDF, so the doctor
                     sees what each section will look like before applying. -->
                <div invisible="mode != 'report'">
                    <separator string="1. History of Present Illness (S)"/>
                    <field name="report_history_present_illness"
                           nolabel="1"/>

                    <separator string="2. Physical Examination (O)"/>
                    <field name="report_physical_exam"
                           nolabel="1"/>

                    <separator string="3. Assessment (A) / Diagnoses"/>
                    <field name="report_assessment"
                           nolabel="1"/>

                    <separator string="4. Investigations Performed"/>
                    <field name="report_investigations_performed"
                           nolabel="1"/>

                    <separator string="5. Plan (P)"/>
                    <field name="report_plan"
                           nolabel="1"/>

                    <separator string="6. Therapies Administered"/>
                    <field name="report_therapies_administered"
                           nolabel="1"/>

                    <separator string="7. Medications Prescribed upon Discharge"/>
                    <field name="report_discharge_medication_notes"
                           nolabel="1"/>

                    <separator string="8. Condition at Discharge"/>
                    <field name="report_discharge_condition"
                           nolabel="1"/>

                    <separator string="9. Conclusion"/>
                    <field name="report_discharge_conclusion"
                           nolabel="1"/>
                </div>

                <!-- Case report summary: the case-level narrative sections
                     plus one editable timeline note per linked encounter. -->
                <div invisible="mode != 'case'">
                    <separator string="Cause of Injury / Illness"/>
                    <field name="case_cause" nolabel="1"/>

                    <separator string="Initial Medical Diagnosis"/>
                    <field name="case_initial_diagnosis" nolabel="1"/>

                    <separator string="Current Medical Complaint"/>
                    <field name="case_current_complaint" nolabel="1"/>

                    <separator string="Sick Leave"/>
                    <field name="case_sick_leave" nolabel="1"/>

                    <separator string="Encounter Timeline (one row per visit)"/>
                    <field name="timeline_line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="encounter_date" readonly="1"/>
                            <field name="encounter_type" readonly="1"/>
                            <field name="note"/>
                        </list>
                    </field>
                </div>

                <!-- Diagnosis suggestions -->
                <group invisible="mode != 'diagnosis'">
                    <field name="suggested_diagnosis_ids"
                           widget="many2many_tags" nolabel="1"/>
                </group>

                <!-- Free-text output: rationale / summary / safety findings -->
                <group invisible="mode in ('report', 'case')">
                    <field name="result_text" nolabel="1" readonly="1"/>
                </group>

                <footer>
                    <button name="action_apply_report" type="object"
                            string="Apply to Encounter" class="btn-primary"
                            invisible="mode != 'report'"/>
                    <button name="action_apply_case" type="object"
                            string="Apply to Case" class="btn-primary"
                            invisible="mode != 'case'"/>
                    <button name="action_apply_diagnoses" type="object"
                            string="Add Diagnoses to Encounter"
                            class="btn-primary"
                            invisible="mode != 'diagnosis'"/>
                    <button string="Close" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
