<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_insurance_card_scan_wizard_form" model="ir.ui.view">
        <field name="name">medical.insurance.card.scan.wizard.form</field>
        <field name="model">medical.insurance.card.scan.wizard</field>
        <field name="arch" type="xml">
            <form string="Scan Insurance Card">
                <field name="state" invisible="1"/>
                <field name="patient_id" invisible="1"/>

                <!-- Step 1: upload -->
                <group invisible="state != 'upload'">
                    <div class="alert alert-info" role="alert" colspan="2">
                        <strong>Scan a private insurance card.</strong>
                        Upload the front (required) and back (optional) of the
                        card. Bilingual cards (Arabic/English) are supported.
                        The extracted data is shown for review before anything
                        is saved.
                    </div>
                    <group>
                        <field name="image_front" widget="image"
                               filename="image_front_filename"
                               options="{'size': [400, 260]}"/>
                        <field name="image_front_filename" invisible="1"/>
                    </group>
                    <group>
                        <field name="image_back" widget="image"
                               filename="image_back_filename"
                               options="{'size': [400, 260]}"/>
                        <field name="image_back_filename" invisible="1"/>
                    </group>
                </group>

                <!-- Step 2: review -->
                <group invisible="state != 'review'">
                    <div class="alert alert-warning" role="alert" colspan="2">
                        <strong>Review before applying.</strong>
                        OCR can mis-read numbers. Check the policy number,
                        validity dates and copay percentages carefully.
                    </div>
                    <group string="Cardholder &amp; Policy">
                        <field name="policy_holder_name"/>
                        <field name="policy_number"/>
                        <field name="employee_code"/>
                        <field name="department"/>
                    </group>
                    <group string="Coverage">
                        <field name="insurance_company"/>
                        <field name="insurance_provider_id"
                               options="{'no_quick_create': True}"/>
                        <field name="network_name"/>
                        <field name="plan_name"/>
                    </group>
                    <group string="Validity">
                        <field name="valid_from"/>
                        <field name="valid_to"/>
                    </group>
                    <group string="Cost sharing">
                        <field name="copay_outpatient_pct"/>
                        <field name="copay_medication_pct"/>
                        <field name="copay_chronic_pct"/>
                        <field name="room_class"/>
                    </group>
                    <group string="Covered hospitals / notes" col="1">
                        <field name="covered_hospitals" nolabel="1"/>
                        <field name="notes" nolabel="1"/>
                    </group>
                    <group string="Raw OCR" col="1">
                        <field name="raw_text" nolabel="1"
                               widget="text" readonly="1"/>
                    </group>
                </group>

                <footer>
                    <button name="action_scan" type="object"
                            string="Scan" class="btn-primary"
                            invisible="state != 'upload'"/>
                    <button name="action_apply" type="object"
                            string="Apply" class="btn-primary"
                            invisible="state != 'review'"/>
                    <button name="action_back_to_upload" type="object"
                            string="Try Another Image" class="btn-secondary"
                            invisible="state != 'review'"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_medical_insurance_card_scan_wizard"
            model="ir.actions.act_window">
        <field name="name">Scan Insurance Card</field>
        <field name="res_model">medical.insurance.card.scan.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
