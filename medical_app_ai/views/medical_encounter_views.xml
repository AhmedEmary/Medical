<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add an AI assist toolbar to the encounter's Consultation tab -->
    <record id="view_medical_encounter_form_ai" model="ir.ui.view">
        <field name="name">medical.encounter.form.ai</field>
        <field name="model">medical.encounter</field>
        <field name="inherit_id" ref="medical_app.view_medical_encounter_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='consultation']/group[1]"
                   position="before">
                <div class="o_row mb-3" groups="medical_app.group_medical_doctor">
                    <button name="action_ai_draft_soap" type="object"
                            string="Draft SOAP" icon="fa-magic"
                            class="btn-secondary"
                            help="Draft the SOAP note from this encounter's data"/>
                    <button name="action_ai_suggest_diagnoses" type="object"
                            string="Suggest Diagnoses" icon="fa-magic"
                            class="btn-secondary"
                            help="Suggest ICD-10 diagnoses for this encounter"/>
                    <button name="action_ai_summarize_patient" type="object"
                            string="Summarize Patient" icon="fa-magic"
                            class="btn-secondary"
                            help="Summarize the patient's history and context"/>
                    <button name="action_ai_safety_check" type="object"
                            string="Safety Check" icon="fa-magic"
                            class="btn-secondary"
                            help="Check the plan against allergies and medications"/>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
