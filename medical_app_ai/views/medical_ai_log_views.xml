<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_ai_log_list" model="ir.ui.view">
        <field name="name">medical.ai.log.list</field>
        <field name="model">medical.ai.log</field>
        <field name="arch" type="xml">
            <list string="AI Activity"
                  decoration-danger="state == 'error'"
                  decoration-success="applied" create="false">
                <field name="create_date" string="When"/>
                <field name="feature"/>
                <field name="patient_id"/>
                <field name="encounter_id"/>
                <field name="user_id"/>
                <field name="provider" optional="hide"/>
                <field name="model" optional="hide"/>
                <field name="input_tokens" optional="hide" sum="Input"/>
                <field name="output_tokens" optional="hide" sum="Output"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'success'"
                       decoration-danger="state == 'error'"/>
                <field name="applied" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_medical_ai_log_form" model="ir.ui.view">
        <field name="name">medical.ai.log.form</field>
        <field name="model">medical.ai.log</field>
        <field name="arch" type="xml">
            <form string="AI Request">
                <sheet>
                    <group>
                        <group>
                            <field name="feature"/>
                            <field name="patient_id"/>
                            <field name="encounter_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="provider"/>
                            <field name="model"/>
                            <field name="state"/>
                            <field name="applied"/>
                            <field name="input_tokens"/>
                            <field name="output_tokens"/>
                        </group>
                    </group>
                    <group string="Error" invisible="state == 'success'">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Prompt">
                        <field name="request_summary" nolabel="1"/>
                    </group>
                    <group string="Response">
                        <field name="response" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_medical_ai_log_search" model="ir.ui.view">
        <field name="name">medical.ai.log.search</field>
        <field name="model">medical.ai.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_id"/>
                <field name="encounter_id"/>
                <field name="user_id"/>
                <filter string="Success" name="success"
                        domain="[('state', '=', 'success')]"/>
                <filter string="Error" name="error"
                        domain="[('state', '=', 'error')]"/>
                <filter string="Accepted" name="applied"
                        domain="[('applied', '=', True)]"/>
                <group name="group_by">
                    <filter string="Feature" name="g_feature"
                            context="{'group_by': 'feature'}"/>
                    <filter string="Provider" name="g_provider"
                            context="{'group_by': 'provider'}"/>
                    <filter string="Requested By" name="g_user"
                            context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_medical_ai_log" model="ir.actions.act_window">
        <field name="name">AI Activity Log</field>
        <field name="res_model">medical.ai.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_medical_ai_log_search"/>
    </record>

</odoo>
