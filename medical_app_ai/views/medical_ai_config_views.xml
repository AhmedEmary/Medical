<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_ai_config_form" model="ir.ui.view">
        <field name="name">medical.ai.config.form</field>
        <field name="model">medical.ai.config</field>
        <field name="arch" type="xml">
            <form string="AI Configuration">
                <div class="alert alert-info" role="alert">
                    Choose which AI provider the clinical assistant uses and
                    enter the matching API key. Each provider keeps its own
                    key and model, so you can switch between them freely.
                </div>
                <group>
                    <field name="provider"/>
                    <field name="api_key" password="True"
                           placeholder="API key for the selected provider"/>
                    <field name="model" placeholder="e.g. claude-opus-4-7"/>
                    <field name="model_hint" readonly="1"/>
                </group>
                <group string="Doctor controls">
                    <field name="preview_prompts"/>
                </group>
                <footer>
                    <button name="action_save" type="object"
                            string="Save" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_medical_ai_config" model="ir.actions.act_window">
        <field name="name">AI Configuration</field>
        <field name="res_model">medical.ai.config</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
