<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Patient form: 'Scan ID' button in the header -->
    <record id="view_medical_patient_form_ai_scan" model="ir.ui.view">
        <field name="name">medical.patient.form.ai.scan</field>
        <field name="model">medical.patient</field>
        <field name="inherit_id" ref="medical_app.view_medical_patient_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_new_encounter']"
                   position="after">
                <button name="action_scan_id_document" type="object"
                        string="Scan ID Document" icon="fa-id-card"
                        class="btn-secondary"
                        groups="medical_app.group_medical_receptionist"
                        help="Read a passport or national ID image and fill
                              the patient's identity fields automatically."/>
            </xpath>
        </field>
    </record>

    <!-- Contact form: 'Scan ID' stat button alongside the Patient one -->
    <record id="view_partner_form_ai_scan" model="ir.ui.view">
        <field name="name">res.partner.form.ai.scan</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="medical_app.view_partner_form_medical"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_scan_id_document" type="object"
                        class="oe_stat_button" icon="fa-id-card"
                        groups="medical_app.group_medical_receptionist">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Scan ID</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>