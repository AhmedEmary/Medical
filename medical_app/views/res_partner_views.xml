<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_partner_form_medical" model="ir.ui.view">
        <field name="name">res.partner.form.medical</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_patient" type="object"
                        class="oe_stat_button" icon="fa-user-md"
                        invisible="not is_patient"
                        groups="medical_app.group_medical_receptionist">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Patient</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_patient"
                       groups="medical_app.group_medical_receptionist"/>
            </xpath>
        </field>
    </record>

</odoo>
