<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_medical_allergy_form" model="ir.ui.view">
        <field name="name">medical.allergy.form</field>
        <field name="model">medical.allergy</field>
        <field name="arch" type="xml">
            <form string="Allergy">
                <sheet>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="allergen"/>
                            <field name="allergen_type"/>
                            <field name="reaction"/>
                        </group>
                        <group>
                            <field name="severity"/>
                            <field name="onset_date"/>
                            <field name="verified"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
