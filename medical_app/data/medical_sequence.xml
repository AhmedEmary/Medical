<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_medical_patient" model="ir.sequence">
            <field name="name">Medical Patient (MRN)</field>
            <field name="code">medical.patient</field>
            <field name="prefix">PAT/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_medical_encounter" model="ir.sequence">
            <field name="name">Medical Encounter</field>
            <field name="code">medical.encounter</field>
            <field name="prefix">ENC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_medical_external_visit" model="ir.sequence">
            <field name="name">External Physician Visit</field>
            <field name="code">medical.external.visit</field>
            <field name="prefix">EXT/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
