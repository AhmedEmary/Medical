<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Inherit the standard customer invoice PDF to inject a
        "Patient Information" block (medical-invoice standard layout)
        whenever the invoice is linked to a clinical encounter OR
        the invoice contact is a registered patient.

        Block is placed immediately below the address / invoice header
        block and above the line items so the patient identity is the
        first thing seen, as required for medical billing.

        Each individual field row is wrapped in ``t-if`` so empty
        values are not printed at all.
    -->
    <template id="report_invoice_document_inherit_medical"
              inherit_id="account.report_invoice_document">
        <xpath expr="//div[hasclass('page')]//table[1]"
               position="before">
            <t t-if="o.is_medical_invoice and o.patient_id">
                <div style="page-break-inside: avoid; margin:0 0 14px 0;
                            padding:10px 14px;
                            border:1px solid #cbd5e1;
                            background:#f8fafc; border-radius:4px;
                            font-size:10pt; color:#1f2d3d;">

                    <h4 style="color:#1f5e8a; margin:0 0 8px 0;
                               border-bottom:1px solid #cbd5e1;
                               padding-bottom:4px;">
                        <strong>Patient Information</strong>
                    </h4>

                    <div style="font-size:10pt; margin:0 0 6px 0;">
                        <div t-if="o.patient_id.name"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Patient Name:</strong>
                            <span t-out="o.patient_id.name"/>
                        </div>
                        <div t-if="o.medical_mrn"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>MRN:</strong>
                            <span t-out="o.medical_mrn"/>
                        </div>
                        <div t-if="o.medical_passport"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Passport / National ID:</strong>
                            <span t-out="o.medical_passport"/>
                        </div>
                        <div t-if="o.medical_nationality_id"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Nationality:</strong>
                            <span t-out="o.medical_nationality_id.name"/>
                        </div>
                        <div t-if="o.medical_date_of_birth"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Date of Birth:</strong>
                            <span t-field="o.medical_date_of_birth"
                                  t-options='{"format": "dd / MM / yyyy"}'/>
                            <t t-if="o.medical_age_display">
                                (<span t-out="o.medical_age_display"/>)
                            </t>
                        </div>
                        <div t-if="o.medical_gender"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Gender:</strong>
                            <span t-field="o.medical_gender"/>
                        </div>
                        <div t-if="o.medical_mobile"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Mobile:</strong>
                            <span t-out="o.medical_mobile"/>
                        </div>
                        <div t-if="o.medical_hotel_name"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Hotel:</strong>
                            <span t-out="o.medical_hotel_name"/>
                        </div>
                        <div t-if="o.medical_room_number"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Room Number:</strong>
                            <span t-out="o.medical_room_number"/>
                        </div>
                        <div t-if="o.encounter_id and (o.encounter_id.doctor_employee_id or o.encounter_id.doctor_id)"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Attending Physician:</strong>
                            <span t-out="o.encounter_id.doctor_employee_id.name or o.encounter_id.doctor_id.name"/>
                        </div>
                    </div>

                    <t t-if="o.medical_insurance_provider_id or o.medical_insurance_policy_number or o.medical_reference_number or o.medical_insurance_valid_until or o.medical_insurance_assistance_company_id or o.medical_insurance_franchise">
                        <h4 style="color:#1f5e8a; margin:10px 0 6px 0;
                                   border-bottom:1px solid #cbd5e1;
                                   padding-bottom:4px;">
                            <strong>Insurance Information</strong>
                        </h4>
                        <div style="font-size:10pt; margin:0;">
                            <div t-if="o.medical_insurance_provider_id"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Insurance Company:</strong>
                                <span t-out="o.medical_insurance_provider_id.name"/>
                            </div>
                            <div t-if="o.medical_insurance_policy_number"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Policy Number:</strong>
                                <span t-out="o.medical_insurance_policy_number"/>
                            </div>
                            <div t-if="o.medical_reference_number"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Reference Number:</strong>
                                <span t-out="o.medical_reference_number"/>
                            </div>
                            <div t-if="o.medical_insurance_valid_until"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Valid Until:</strong>
                                <span t-field="o.medical_insurance_valid_until"
                                      t-options='{"format": "dd / MM / yyyy"}'/>
                            </div>
                            <div t-if="o.medical_insurance_assistance_company_id"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Assistance Company:</strong>
                                <span t-out="o.medical_insurance_assistance_company_id.name"/>
                            </div>
                            <div t-if="o.medical_insurance_franchise"
                                 style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                                <strong>Franchise:</strong>
                                <span t-out="o.medical_insurance_franchise"/>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>

        <!--
            Enrich the standard "Payment Communication / on this account"
            line with a structured Bank Details block listing the
            IBAN (account number), SWIFT / BIC and bank address.
            Each row is wrapped in t-if so empty values are not printed.
        -->
        <xpath expr="//p[@name='payment_communication']" position="after">
            <t t-if="o.partner_bank_id">
                <t t-set="_bank" t-value="o.partner_bank_id.bank_id"/>
                <div name="bank_details"
                     style="page-break-inside: avoid; margin:0 0 14px 0;
                            padding:10px 14px;
                            border:1px solid #cbd5e1;
                            background:#f8fafc; border-radius:4px;
                            font-size:10pt; color:#1f2d3d;">
                    <h4 style="color:#1f5e8a; margin:0 0 8px 0;
                               border-bottom:1px solid #cbd5e1;
                               padding-bottom:4px;">
                        <strong>Bank Details</strong>
                    </h4>
                    <div style="font-size:10pt; margin:0;">
                        <div t-if="_bank.name"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Bank Name:</strong>
                            <span t-out="_bank.name"/>
                        </div>
                        <div t-if="o.partner_bank_id.acc_holder_name or o.partner_bank_id.partner_id"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Account Holder:</strong>
                            <span t-out="o.partner_bank_id.acc_holder_name or o.partner_bank_id.partner_id.name"/>
                        </div>
                        <div t-if="o.partner_bank_id.acc_number"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>IBAN / Account Number:</strong>
                            <span t-out="o.partner_bank_id.acc_number"/>
                        </div>
                        <div t-if="o.partner_bank_id.bank_bic"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>SWIFT / BIC:</strong>
                            <span t-out="o.partner_bank_id.bank_bic"/>
                        </div>
                        <div t-if="o.partner_bank_id.currency_id"
                             style="display:inline-block; width:49%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Currency:</strong>
                            <span t-out="o.partner_bank_id.currency_id.name"/>
                        </div>
                        <div t-if="_bank.street or _bank.street2 or _bank.city or _bank.state or _bank.zip or _bank.country"
                             style="display:block; width:100%; vertical-align:top; padding:2px 4px; box-sizing:border-box;">
                            <strong>Bank Address:</strong>
                            <span>
                                <t t-if="_bank.street"><t t-out="_bank.street"/></t>
                                <t t-if="_bank.street2">, <t t-out="_bank.street2"/></t>
                                <t t-if="_bank.city">, <t t-out="_bank.city"/></t>
                                <t t-if="_bank.state">, <t t-out="_bank.state.name"/></t>
                                <t t-if="_bank.zip"> <t t-out="_bank.zip"/></t>
                                <t t-if="_bank.country">, <t t-out="_bank.country.name"/></t>
                            </span>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

</odoo>