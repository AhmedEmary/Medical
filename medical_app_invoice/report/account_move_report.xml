<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Inherit the standard customer invoice PDF to inject a
        "Patient Information" block (medical-invoice standard layout)
        whenever the invoice is linked to a clinical encounter OR
        the invoice contact is a registered patient.

        Block is placed immediately below the address / invoice header
        block and above the line items so the patient identity is the
        first thing seen, as required for medical billing.

        Each individual field row is wrapped in ``t-if`` so empty
        values are not printed at all.
    -->
    <template id="report_invoice_document_inherit_medical"
              inherit_id="account.report_invoice_document">
        <xpath expr="//div[hasclass('page')]//table[1]"
               position="before">
            <t t-if="o.is_medical_invoice and o.patient_id">
                <div style="page-break-inside: avoid; margin:0 0 14px 0;
                            padding:10px 14px;
                            border:1px solid #cbd5e1;
                            background:#f8fafc; border-radius:4px;
                            font-size:10pt; color:#1f2d3d;">

                    <h4 style="color:#1f5e8a; margin:0 0 8px 0;
                               border-bottom:1px solid #cbd5e1;
                               padding-bottom:4px;">
                        <strong>Patient Information</strong>
                    </h4>

                    <table class="table table-borderless table-sm"
                           style="margin:0 0 6px 0; font-size:10pt;">
                        <tr t-if="o.patient_id.name">
                            <td style="width:30%;">
                                <strong>Patient Name:</strong>
                            </td>
                            <td>
                                <span t-out="o.patient_id.name"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_mrn">
                            <td style="width:30%;">
                                <strong>MRN:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_mrn"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_passport">
                            <td style="width:30%;">
                                <strong>Passport / National ID:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_passport"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_nationality_id">
                            <td style="width:30%;">
                                <strong>Nationality:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_nationality_id.name"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_date_of_birth">
                            <td style="width:30%;">
                                <strong>Date of Birth:</strong>
                            </td>
                            <td>
                                <span t-field="o.medical_date_of_birth"
                                      t-options='{"format": "dd / MM / yyyy"}'/>
                                <t t-if="o.medical_age_display">
                                    (<span t-out="o.medical_age_display"/>)
                                </t>
                            </td>
                        </tr>
                        <tr t-if="o.medical_gender">
                            <td style="width:30%;">
                                <strong>Gender:</strong>
                            </td>
                            <td>
                                <span t-field="o.medical_gender"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_mobile">
                            <td style="width:30%;">
                                <strong>Mobile:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_mobile"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_hotel_name">
                            <td style="width:30%;">
                                <strong>Hotel:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_hotel_name"/>
                            </td>
                        </tr>
                        <tr t-if="o.medical_room_number">
                            <td style="width:30%;">
                                <strong>Room Number:</strong>
                            </td>
                            <td>
                                <span t-out="o.medical_room_number"/>
                            </td>
                        </tr>
                        <tr t-if="o.encounter_id and (o.encounter_id.doctor_employee_id or o.encounter_id.doctor_id)">
                            <td style="width:30%;">
                                <strong>Attending Physician:</strong>
                            </td>
                            <td>
                                <span t-out="o.encounter_id.doctor_employee_id.name or o.encounter_id.doctor_id.name"/>
                            </td>
                        </tr>
                    </table>

                    <t t-if="o.medical_insurance_provider_id or o.medical_insurance_policy_number or o.medical_insurance_valid_until">
                        <h4 style="color:#1f5e8a; margin:10px 0 6px 0;
                                   border-bottom:1px solid #cbd5e1;
                                   padding-bottom:4px;">
                            <strong>Insurance Information</strong>
                        </h4>
                        <table class="table table-borderless table-sm"
                               style="margin:0; font-size:10pt;">
                            <tr t-if="o.medical_insurance_provider_id">
                                <td style="width:30%;">
                                    <strong>Insurance Company:</strong>
                                </td>
                                <td>
                                    <span t-out="o.medical_insurance_provider_id.name"/>
                                </td>
                            </tr>
                            <tr t-if="o.medical_insurance_policy_number">
                                <td style="width:30%;">
                                    <strong>Policy Number:</strong>
                                </td>
                                <td>
                                    <span t-out="o.medical_insurance_policy_number"/>
                                </td>
                            </tr>
                            <tr t-if="o.medical_insurance_valid_until">
                                <td style="width:30%;">
                                    <strong>Valid Until:</strong>
                                </td>
                                <td>
                                    <span t-field="o.medical_insurance_valid_until"
                                          t-options='{"format": "dd / MM / yyyy"}'/>
                                </td>
                            </tr>
                        </table>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

</odoo>