<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Adds a "Medical Encounter" section to the customer invoice form,
        with the encounter link and (when set) the patient's passport
        and insurance details.
    -->
    <record id="view_move_form_inherit_medical" model="ir.ui.view">
        <field name="name">account.move.form.medical</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Stat-button counterpart: jump back to the encounter -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_encounter" type="object"
                        class="oe_stat_button" icon="fa-stethoscope"
                        invisible="not encounter_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Encounter</span>
                        <span class="o_stat_value">
                            <field name="encounter_id" readonly="1"
                                   options="{'no_open': True}"/>
                        </span>
                    </div>
                </button>
            </xpath>

            <!-- A medical-encounter notebook page (last tab) -->
            <xpath expr="//notebook" position="inside">
                <page string="Medical Encounter" name="medical_encounter_page"
                      invisible="not is_medical_invoice">
                    <field name="is_medical_invoice" invisible="1"/>
                    <group>
                        <group string="Encounter">
                            <field name="encounter_id" readonly="1"
                                   options="{'no_open': False}"/>
                            <field name="patient_id" readonly="1"
                                   options="{'no_open': True}"/>
                            <field name="medical_passport"/>
                        </group>
                        <group string="Insurance">
                            <field name="medical_insurance_provider_id"
                                   options="{'no_open': True}"/>
                            <field name="medical_insurance_policy_number"/>
                            <field name="medical_insurance_coverage_type"/>
                            <field name="medical_insurance_valid_until"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
