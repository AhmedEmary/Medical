<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Adds a "Medical Information" section to the customer invoice form,
        with patient identity, demographics, hotel/room (if applicable),
        and insurance details. The section is visible whenever the contact
        is a registered patient or the invoice is linked to a clinical
        encounter.
    -->
    <record id="view_move_form_inherit_medical" model="ir.ui.view">
        <field name="name">account.move.form.medical</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!--
                'Scan Invoice' header button — uploads an invoice image,
                runs AI OCR, lets the user review the extracted header
                and lines, and applies them to this draft invoice.
                Only available on draft customer invoices.
            -->
            <xpath expr="//header" position="inside">
                <button name="action_scan_invoice_document" type="object"
                        string="Scan Invoice" icon="fa-camera"
                        class="btn-secondary"
                        invisible="state != 'draft' or move_type not in ('out_invoice', 'out_refund')"
                        help="Upload a photo or scan of an invoice; the AI
                              extracts the header and line items and
                              pre-fills this draft for you to review."/>
            </xpath>

            <!-- Stat-button counterpart: jump back to the encounter -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_view_encounter" type="object"
                        class="oe_stat_button" icon="fa-stethoscope"
                        invisible="not encounter_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Encounter</span>
                        <span class="o_stat_value">
                            <field name="encounter_id" readonly="1"
                                   options="{'no_open': True}"/>
                        </span>
                    </div>
                </button>
            </xpath>

            <!-- A medical-information notebook page (last tab) -->
            <xpath expr="//notebook" position="inside">
                <page string="Medical Information" name="medical_encounter_page"
                      invisible="not is_medical_invoice">
                    <field name="is_medical_invoice" invisible="1"/>
                    <field name="patient_id" invisible="1"/>
                    <group>
                        <group string="Patient">
                            <field name="patient_id" readonly="1"
                                   options="{'no_open': False}"/>
                            <field name="medical_mrn"/>
                            <field name="medical_passport"/>
                            <field name="medical_date_of_birth"/>
                            <field name="medical_age_display"/>
                            <field name="medical_gender"/>
                            <field name="medical_nationality_id"
                                   options="{'no_open': True}"/>
                            <field name="medical_mobile"/>
                        </group>
                        <group string="Stay &amp; Encounter">
                            <field name="medical_hotel_name"/>
                            <field name="medical_room_number"/>
                            <field name="encounter_id" readonly="1"
                                   options="{'no_open': False}"/>
                        </group>
                        <group string="Insurance" colspan="2">
                            <field name="medical_insurance_provider_id"
                                   options="{'no_open': True}"/>
                            <field name="medical_insurance_policy_number"/>
                            <field name="medical_insurance_valid_until"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>