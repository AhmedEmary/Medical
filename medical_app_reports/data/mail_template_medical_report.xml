<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        Mail template used by the "Send by Email" button on the encounter
        form. ``report_template_ids`` points at the medical report action,
        so the PDF is attached automatically by the standard mail composer
        — same mechanism Odoo uses for invoice / sales-order emails.
    -->
    <record id="email_template_medical_report" model="mail.template">
        <field name="name">Medical Report: Send to Patient</field>
        <field name="model_id" ref="medical_app.model_medical_encounter"/>
        <field name="subject">Medical Report - {{ object.reference }}</field>
        <field name="partner_to">{{ object.patient_id.partner_id.id }}</field>
        <field name="email_from">{{ (object.doctor_id.email_formatted or user.email_formatted) }}</field>
        <field name="description">
            Sent to the patient with the medical report PDF attached.
        </field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p>
                    Dear <t t-out="object.patient_id.name or ''"/>,
                </p>
                <p>
                    Please find attached your medical report
                    <t t-if="object.encounter_date">
                        for the visit on
                        <t t-out="format_date(object.encounter_date)"/>
                    </t>.
                </p>
                <p>
                    For any questions, please reply to this email
                    <t t-if="object.doctor_id.company_id.phone">
                        or call us at
                        <t t-out="object.doctor_id.company_id.phone"/>
                    </t>.
                </p>
                <p>
                    Best regards,<br/>
                    <t t-out="object.doctor_id.name or user.name"/>
                </p>
            </div>
        </field>
        <field name="report_template_ids"
               eval="[(4, ref('action_report_medical_encounter'))]"/>
        <field name="lang">{{ object.patient_id.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
