<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Medical encounter report.

        Simple layout that follows the reference PDF:
          * Standard Odoo ``web.external_layout`` provides the company
            header (logo + bilingual department title) and the footer
            (phone / email, tax ID / registry, page number). The header
            and footer come from the company's Document Layout setup, so
            nothing is hard-coded here.
          * Section headings are blue, bold and underlined.
          * Body text is plain paragraphs, simple bullet lists and a
            single bordered table for vital signs — no cards, borders
            or accent stripes around sections.
    -->

    <template id="report_medical_encounter">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="medical_app_reports.report_medical_encounter_document"
                   t-lang="user.lang or 'en_US'"/>
            </t>
        </t>
    </template>

    <template id="report_medical_encounter_document">
        <t t-call="web.external_layout">
            <t t-set="patient" t-value="o.patient_id"/>

            <div class="page">

                <!-- ============= Personal Information ============= -->
                <h3 style="color:#1f5e8a; text-decoration:underline;">
                    <strong>Personal Information:</strong>
                </h3>
                <table class="table table-borderless" style="margin-bottom:16px;">
                    <tr>
                        <td style="width:35%;"><strong>Name:</strong></td>
                        <td><span t-out="patient.name"/></td>
                    </tr>
                    <tr>
                        <td><strong>Gender:</strong></td>
                        <td>
                            <span t-out="dict(patient._fields['gender'].selection).get(patient.gender, '')"/>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Age:</strong></td>
                        <td>
                            <t t-if="patient.age">
                                <span t-out="patient.age"/> years old
                            </t>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Date:</strong></td>
                        <td>
                            <span t-if="o.encounter_date"
                                  t-field="o.encounter_date"
                                  t-options='{"format": "dd.MM.yyyy"}'/>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Medical Record Number (MRN)</strong></td>
                        <td><span t-out="patient.mrn"/></td>
                    </tr>
                </table>

                <!-- ============= Clinical Summary ============= -->
                <t t-if="o.history_present_illness">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Clinical Summary:</strong>
                    </h3>
                    <div style="text-align:justify;">
                        <t t-out="o.history_present_illness"/>
                    </div>
                </t>

                <!-- ============= Urgency Level ============= -->
                <t t-if="o.urgency_level">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Urgency Level:</strong>
                    </h3>
                    <t t-set="pal" t-value="o._urgency_palette()"/>
                    <p>
                        <span t-attf-style="display:inline-block; width:12px;
                                            height:12px; border-radius:50%;
                                            background:{{pal['dot']}};
                                            vertical-align:middle;
                                            margin-right:8px;"/>
                        <strong style="vertical-align:middle;"
                                t-out="o._urgency_label()"/>
                    </p>
                </t>

                <!-- ============= Clinical Notes & Course ============= -->
                <t t-set="show_history"
                   t-value="patient.medical_history_ids or patient.active_medication_ids"/>
                <t t-if="show_history or o.therapies_administered">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Clinical Notes &amp; Course:</strong>
                    </h3>
                </t>

                <t t-if="show_history">
                    <h4 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Patient History:</strong>
                    </h4>
                    <ul>
                        <li t-foreach="patient.medical_history_ids" t-as="h">
                            <span t-out="h.condition"/>
                            <t t-if="h.status">
                                (<span t-out="dict(h._fields['status'].selection).get(h.status, '')"/>)
                            </t>
                        </li>
                        <li t-foreach="patient.active_medication_ids" t-as="m">
                            The patient is currently on
                            <strong t-out="m.product_name"/>
                            <t t-if="m.dose">, <span t-out="m.dose"/></t>
                            <t t-if="m.indication">
                                for <span t-out="m.indication"/>
                            </t>.
                        </li>
                    </ul>
                </t>

                <t t-if="o.therapies_administered">
                    <h4 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Therapies Administered</strong>
                    </h4>
                    <div>
                        <t t-out="o.therapies_administered"/>
                    </div>
                </t>

                <!-- ============= Vital Signs ============= -->
                <t t-if="o.vitals_ids">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Vital Signs Table:</strong>
                    </h3>
                    <table class="table table-bordered"
                           style="text-align:center; font-size:10pt;">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Date</th>
                                <th>BP</th>
                                <th>Temperature</th>
                                <th>Pulse</th>
                                <th>RBS</th>
                                <th>RR</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.vitals_ids.sorted('measurement_time')"
                                t-as="v">
                                <td>
                                    <span t-if="v.measurement_time"
                                          t-field="v.measurement_time"
                                          t-options='{"format": "hh:mm a"}'/>
                                </td>
                                <td>
                                    <span t-if="v.measurement_time"
                                          t-field="v.measurement_time"
                                          t-options='{"format": "dd.MM.yyyy"}'/>
                                </td>
                                <td><span t-out="v.bp_display or ''"/></td>
                                <td>
                                    <t t-if="v.temperature">
                                        <span t-out="v.temperature"/>
                                    </t>
                                </td>
                                <td>
                                    <t t-if="v.heart_rate">
                                        <span t-out="v.heart_rate"/>
                                    </t>
                                </td>
                                <td>
                                    <t t-if="v.glucose">
                                        <span t-out="v.glucose"/>
                                    </t>
                                </td>
                                <td>
                                    <t t-if="v.respiratory_rate">
                                        <span t-out="v.respiratory_rate"/>
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </t>

                <!-- ============= Diagnosis ============= -->
                <t t-if="o.diagnosis_ids">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Diagnosis:</strong>
                    </h3>
                    <p style="text-align:center;">
                        <strong t-out="' and '.join(o.diagnosis_ids.mapped('name'))"/>
                    </p>
                </t>

                <!-- ============= Medications Prescribed upon Discharge ============= -->
                <t t-if="o.prescription_line_ids or o.discharge_medication_notes">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Medications Prescribed upon Discharge:</strong>
                    </h3>

                    <t t-if="o.discharge_medication_notes">
                        <div style="text-align:justify;">
                            <t t-out="o.discharge_medication_notes"/>
                        </div>
                    </t>

                    <t t-if="o.prescription_line_ids">
                        <p>The prescribed treatment plan includes:</p>
                        <ul>
                            <li t-foreach="o.prescription_line_ids" t-as="rx">
                                <strong t-out="rx.product_name or ''"/>
                                <t t-if="rx.dose">: <span t-out="rx.dose"/></t>
                                <t t-if="rx._frequency_label()">,
                                    <span t-out="rx._frequency_label()"/>
                                </t>
                                <t t-if="rx._route_label()">
                                    (<span t-out="rx._route_label()"/>)
                                </t>
                                <t t-if="rx.duration_days">
                                    for <span t-out="rx.duration_days"/> days
                                </t>
                                <t t-if="rx.instructions">
                                    — <span t-out="rx.instructions"/>
                                </t>
                            </li>
                        </ul>
                    </t>
                </t>

                <!-- ============= Medical Recommendation ============= -->
                <t t-if="o.plan">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Medical Recommendation:</strong>
                    </h3>
                    <div style="text-align:justify;">
                        <t t-out="o.plan"/>
                    </div>
                </t>

                <!-- ============= Condition at Discharge ============= -->
                <t t-if="o.discharge_condition">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Condition at Discharge:</strong>
                    </h3>
                    <div style="text-align:justify;">
                        <t t-out="o.discharge_condition"/>
                    </div>
                </t>

                <!-- ============= Conclusion ============= -->
                <t t-if="o.discharge_conclusion">
                    <h3 style="color:#1f5e8a; text-decoration:underline;">
                        <strong>Conclusion:</strong>
                    </h3>
                    <div style="text-align:justify;">
                        <t t-out="o.discharge_conclusion"/>
                    </div>
                </t>

                <!-- ============= Signature ============= -->
                <t t-if="o.doctor_id">
                    <div style="margin-top:24px;">
                        <p style="margin-bottom:2px;">
                            <strong style="text-decoration:underline;">
                                Report prepared and reviewed by:
                            </strong>
                        </p>
                        <p style="margin:0;">
                            <strong>Dr. <span t-out="o.doctor_id.name"/></strong>
                        </p>
                        <p style="margin:0;">
                            <t t-if="o.doctor_id.partner_id.function">
                                <span t-out="o.doctor_id.partner_id.function"/>
                            </t>
                            <t t-else="">Medical Officer</t>
                        </p>
                        <p style="margin:0;">
                            <strong>Date: </strong>
                            <span t-if="o.report_date"
                                  t-field="o.report_date"
                                  t-options='{"format": "dd.MM.yyyy"}'/>
                        </p>
                        <p style="color:#c0392b; font-size:9pt; margin-top:10px;">
                            This report is generated electronically and does not require a stamp.
                        </p>
                    </div>
                </t>

            </div>
        </t>
    </template>

</odoo>
