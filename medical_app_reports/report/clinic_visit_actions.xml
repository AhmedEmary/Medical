<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_clinic_visit" model="ir.actions.report">
        <field name="name">Clinic Visit Note</field>
        <field name="model">medical.encounter</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">medical_app_reports.report_clinic_visit</field>
        <field name="report_file">medical_app_reports.report_clinic_visit</field>
        <field name="print_report_name">
            "Clinic Visit - %s" % (object.reference or object.id)
        </field>
        <field name="binding_model_id" ref="medical_app.model_medical_encounter"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
