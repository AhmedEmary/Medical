<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        External Physician Visit Declaration — printed when a physician
        who is NOT on the hotel's contracted team visits a guest. Documents
        the guest, the visiting doctor's credentials, and disclaims the
        hotel medical provider's responsibility for the care delivered.
    -->

    <template id="report_external_physician_visit">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="medical_app_reports.report_external_physician_visit_document"
                   t-lang="user.lang or 'en_US'"/>
            </t>
        </t>
    </template>

    <template id="report_external_physician_visit_document">
        <t t-call="web.external_layout">
            <div class="page" style="font-size:11pt; color:#1f2d3d;">

                <!-- ============= Title ============= -->
                <div style="text-align:center; margin-bottom:18px;">
                    <h2 style="color:#1f5e8a; margin:0; letter-spacing:0.5px;">
                        <strong>External Physician Visit Declaration</strong>
                    </h2>
                </div>

                <hr style="border:none; border-top:1px solid #cfd8e3;
                           margin-bottom:18px;"/>

                <!-- ============= Heading line + date/time ============= -->
                <h3 style="color:#1f5e8a; margin:0 0 12px 0;">
                    <strong>External Physician Visit Declaration</strong>
                </h3>

                <t t-if="o.visit_date">
                    <p style="margin:4px 0;">
                        <strong>Date:</strong>
                        <span t-field="o.visit_date"
                              t-options='{"format": "dd / MM / yyyy"}'/>
                    </p>
                    <p style="margin:4px 0 16px 0;">
                        <strong>Time:</strong>
                        <span t-field="o.visit_date"
                              t-options='{"format": "HH:mm"}'/>
                    </p>
                </t>

                <!-- ============= Guest Information ============= -->
                <t t-if="o.guest_name or o.hotel_name or o.room_number">
                    <h3 style="color:#1f5e8a; margin:12px 0 8px 0;">
                        <strong>Guest Information</strong>
                    </h3>
                    <ul style="margin:0 0 16px 18px; padding:0; line-height:1.7;">
                        <li t-if="o.guest_name">
                            <strong>Guest Name:</strong>
                            <span t-out="o.guest_name"/>
                        </li>
                        <li t-if="o.hotel_name">
                            <strong>Hotel Name:</strong>
                            <span t-out="o.hotel_name"/>
                        </li>
                        <li t-if="o.room_number">
                            <strong>Room Number:</strong>
                            <span t-out="o.room_number"/>
                        </li>
                    </ul>
                </t>

                <!-- ============= External Physician Information ============= -->
                <t t-if="o.physician_name or o.physician_national_id or o.syndicate_no or o.specialty or o.physician_mobile">
                    <h3 style="color:#1f5e8a; margin:12px 0 8px 0;">
                        <strong>External Physician Information</strong>
                    </h3>
                    <ul style="margin:0 0 16px 18px; padding:0; line-height:1.7;">
                        <li t-if="o.physician_name">
                            <strong>Physician Name:</strong>
                            <span t-out="o.physician_name"/>
                        </li>
                        <li t-if="o.physician_national_id">
                            <strong>National ID / Passport No.:</strong>
                            <span t-out="o.physician_national_id"/>
                        </li>
                        <li t-if="o.syndicate_no">
                            <strong>Medical Syndicate Registration No.:</strong>
                            <span t-out="o.syndicate_no"/>
                        </li>
                        <li t-if="o.specialty">
                            <strong>Specialty:</strong>
                            <span t-out="o.specialty"/>
                        </li>
                        <li t-if="o.physician_mobile">
                            <strong>Mobile Number:</strong>
                            <span t-out="o.physician_mobile"/>
                        </li>
                    </ul>
                </t>

                <!-- ============= Ambulance Information ============= -->
                <t t-if="o.ambulance_plate_number or o.ambulance_brand or o.ambulance_model or o.ambulance_vehicle_type or o.ambulance_color or o.ambulance_chassis_number or o.ambulance_engine_number or o.ambulance_owner_name or o.ambulance_license_expiry">
                    <h3 style="color:#1f5e8a; margin:12px 0 8px 0;">
                        <strong>Ambulance Information</strong>
                    </h3>
                    <ul style="margin:0 0 16px 18px; padding:0; line-height:1.7;">
                        <li t-if="o.ambulance_plate_number">
                            <strong>Plate Number:</strong>
                            <span t-out="o.ambulance_plate_number"/>
                        </li>
                        <li t-if="o.ambulance_brand">
                            <strong>Vehicle Make / Brand:</strong>
                            <span t-out="o.ambulance_brand"/>
                        </li>
                        <li t-if="o.ambulance_model">
                            <strong>Model / Year:</strong>
                            <span t-out="o.ambulance_model"/>
                        </li>
                        <li t-if="o.ambulance_vehicle_type">
                            <strong>Vehicle Type:</strong>
                            <span t-out="o.ambulance_vehicle_type"/>
                        </li>
                        <li t-if="o.ambulance_color">
                            <strong>Color:</strong>
                            <span t-out="o.ambulance_color"/>
                        </li>
                        <li t-if="o.ambulance_chassis_number">
                            <strong>Chassis Number:</strong>
                            <span t-out="o.ambulance_chassis_number"/>
                        </li>
                        <li t-if="o.ambulance_engine_number">
                            <strong>Engine Number:</strong>
                            <span t-out="o.ambulance_engine_number"/>
                        </li>
                        <li t-if="o.ambulance_owner_name">
                            <strong>License Owner Name:</strong>
                            <span t-out="o.ambulance_owner_name"/>
                        </li>
                        <li t-if="o.ambulance_license_expiry">
                            <strong>License Expiry Date:</strong>
                            <span t-field="o.ambulance_license_expiry"
                                  t-options='{"format": "dd / MM / yyyy"}'/>
                        </li>
                    </ul>
                </t>

                <!-- ============= Statement ============= -->
                <h3 style="color:#1f5e8a; margin:18px 0 10px 0;">
                    <strong>Statement</strong>
                </h3>
                <p style="margin:0 0 12px 0; text-align:justify;
                          line-height:1.6;">
                    This is to document that the above-mentioned physician,
                    <strong>who is not affiliated with or authorized by the
                    hotel's contracted medical service provider (Al-Hakim
                    Medicare Pro)</strong>,
                    attended the above-mentioned guest in their hotel room
                    at the guest's and/or companion's own request.
                </p>
                <p style="margin:0 0 12px 0; text-align:justify;
                          line-height:1.6;">
                    The medical assessment, examination, diagnosis, treatment,
                    prescriptions, medical advice, follow-up, and any
                    subsequent medical decisions provided during this visit
                    were carried out
                    <strong>solely by the above-mentioned external
                    physician</strong>,
                    independently of the hotel's medical clinic and its
                    contracted medical team.
                </p>
                <p style="margin:0 0 12px 0; text-align:justify;
                          line-height:1.6;">
                    Accordingly, this visit
                    <strong>does not constitute a medical service provided
                    by the hotel's medical provider</strong>,
                    and all professional responsibility for the medical care
                    delivered during this visit remains with the attending
                    external physician.
                </p>
                <p style="margin:0 0 18px 0; text-align:justify;
                          line-height:1.6;">
                    This declaration is issued solely for documentation
                    purposes within the hotel's records.
                </p>

            </div>
        </t>
    </template>

</odoo>